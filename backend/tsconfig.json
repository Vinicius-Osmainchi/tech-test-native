{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "module": "commonjs",
    "target": "es2022",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "isolatedModules": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "prisma/**/*"]
}
